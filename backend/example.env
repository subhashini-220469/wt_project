# MongoDB Connection URL (Local or Remote)
MONGO_URL=mongodb://localhost:27017/

# OpenRouter API Configuration (for AI scoring)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Gmail SMTP Configuration for Email Automation
# IMPORTANT: Provide your full Gmail address and a 16-character APP PASSWORD.
# Learn how to create an App Password here: 
# https://support.google.com/mail/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
