# Root .gitignore for HireAI project

# Environment Variables
.env
**/.env
**/.env.local
**/.env.development
**/.env.test
**/.env.production

# Node.js
**/node_modules/
**/dist/
**/build/
.npm
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.vite/

# Python
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/venv/
**/.venv/
.pytest_cache/
.coverage
htmlcov/

# OS files
.DS_Store
Thumbs.db
Desktop/

# Editor settings
.vscode/
.idea/
*.swp
*.swo

# Project specific
tmp/
temp/
**/resumes/
backend/data/*.json
!backend/data/template.json
