# Root .gitignore for HireAI project

# Environment Variables
.env
backend/.env
frontend-react/.env
*.env.local
backend/node-backend/.env

# Python files
__pycache__/
backend/__pycache__/
*.py[cod]
*$py.class
venv/
backend/venv/

# Node.js files
node_modules/
frontend-react/node_modules/
dist/
frontend-react/dist/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Search & Editor settings
.vscode/
.idea/
*.swp
*.swo

# Project specific
tmp/
temp/
backend/resumes/
backend/data/*.json
!backend/data/template.json
